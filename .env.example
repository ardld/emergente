# ── Brain (the ONLY API key the system needs) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Models (optional overrides; aliases resolve to latest)
MODEL_CLASSIFY=claude-haiku-4-5
MODEL_SUMMARY=claude-sonnet-4-6
MODEL_CONTEXT=claude-sonnet-4-6

# ── Self-update ("bring itself up to date") ────────────────────────────────
CONTEXT_REGEN_HOURS=20        # regenerate political context at most this often
CONTEXT_LOOKBACK_HOURS=168    # 7-day article window feeding the regeneration
CONTEXT_WEB_SEARCH=true       # augment regeneration with a live web_search pass
# CONTEXT_OVERRIDE="...manual context that beats everything..."

# ── Pipeline ───────────────────────────────────────────────────────────────
LOOKBACK_HOURS=24

# ── Delivery to 2–3 emails/day ─────────────────────────────────────────────
REPORT_RECIPIENTS=mihnead@protonmail.com, oltyboy@gmail.com
SEND_HOUR_LOCAL=8   # daily send time, LOCAL (Europe/Bucharest); DST-proof
REPORT_SUBJECT_PREFIX=Raport politic & tech
REPORT_FROM=Monitorizare <no-reply@contextpolitic.ro>
# Transport A (recommended): a Zapier "Catch Hook" that emails the recipients
ZAPIER_HOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/yyyyy/
# Transport B (optional): SMTP (requires `npm i nodemailer`)
# SMTP_URL=smtps://user:pass@smtp.host:465

# ── Cron protection ────────────────────────────────────────────────────────
CRON_SECRET=change-me-long-random

# ── Durable persistence (STRONGLY recommended on Vercel) ───────────────────
# Without these, the self-updated context + served report won't survive between
# serverless invocations. Create a Vercel KV / Upstash store and paste its vars:
KV_REST_API_URL=https://your-store.upstash.io
KV_REST_API_TOKEN=xxxxxxxx
